{
  "version": 2,
  "buildCommand": "echo 'Static Site Only'",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "https://balance-hub.onrender.com/api/:match*"
    },
    {
      "source": "/uploads/:match*",
      "destination": "https://balance-hub.onrender.com/uploads/:match*"
    }
  ]
}
